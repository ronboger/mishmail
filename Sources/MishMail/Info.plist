<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Merged into the generated Info.plist (GENERATE_INFOPLIST_FILE).
	     Declares mailto: so browsers and other apps can hand off compose
	     links, and so we can offer Settings → default email app. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<!-- Expanded at build time so Debug vs Release labels match bundle id. -->
			<string>$(PRODUCT_BUNDLE_IDENTIFIER).mailto</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>mailto</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
